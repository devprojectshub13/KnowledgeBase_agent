# --- OpenAI: chat agent + semantic chunking ---
LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LLM_MODEL=gpt-4o-mini

# --- OpenAI: embeddings (separate key) ---
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# --- Database (pgvector) ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:9432/agentvector

# --- Chunking / retrieval tuning ---
CHUNK_TARGET_TOKENS=350
SEMANTIC_CHUNK_MAX_TOKENS=4000
TOP_K=5
